{
  "name": "@react-native-ohos/react-native-sound-player",
  "version": "0.14.5-rc.1",
  "description": "Play or stream audio files in ReactNative on harmony",
  "main": "index.js",
  "types": "index.d.ts",
  "keywords": [
    "reactnative",
    "react-native",
    "sound",
    "player",
    "audio",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/react-native-oh-library/react-native-sound-player.git"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": false
  },
  "license": "MIT",
  "dependencies": {
    "react-native-sound-player": "^0.14.5"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "NativeRNSoundPlayer.ts",
    "harmony/rn_sound_player.har",
    "harmony/rn_sound_player",
    "!harmony/oh_modules",
    "!harmony/**/build",
    "!harmony/**/oh_modules"
  ],
  "harmony": {
    "alias": "react-native-sound-player"    
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
